# Railway auto-injects DATABASE_URL when you add a Postgres plugin
DATABASE_URL=postgresql://user:password@localhost:5432/krml250
SECRET_KEY=change-me-to-a-long-random-string
ADMIN_TOKEN=change-me-admin-token
EMAIL_PROVIDER=none
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SENDGRID_API_KEY=
FROM_EMAIL=noreply@krml.com
# Set to your web app's Railway/Vercel URL in production
FRONTEND_URL=http://localhost:3000
# Comma-separated list of allowed CORS origins (use this on Railway instead of CORS_ORIGINS)
CORS_ORIGINS_STR=http://localhost:3000
